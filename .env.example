# Jarvis Desktop Assistant — Environment Configuration
# Copy this file to .env and customize

# ── General ──
JARVIS_ENV=development
JARVIS_DATA_DIR=./data
JARVIS_LOG_LEVEL=INFO

# ── Database ──
DATABASE_URL=sqlite:///data/jarvis.db

# ── LLM Configuration ──
# Primary provider: ollama, openai, anthropic, deepseek, custom
LLM_DEFAULT_PROVIDER=ollama
LLM_DEFAULT_MODEL=llama3.1:8b
LLM_ROUTER_MODEL=phi3:mini
LLM_PLANNER_MODEL=qwen2.5:7b
LLM_ALLOW_CLOUD=false
LLM_CLOUD_FOR_COMPLEX=false

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (optional)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# DeepSeek (optional)
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat

# Custom OpenAI-compatible endpoint (optional)
# CUSTOM_API_KEY=sk-...
# CUSTOM_BASE_URL=http://localhost:8080/v1
# CUSTOM_MODEL=local-model

# ── Voice Configuration ──
VOICE_ENABLED=false
STT_PROVIDER=faster_whisper
STT_MODEL=base
TTS_PROVIDER=edge
WAKE_WORD_ENABLED=false
WAKE_WORD=jarvis

# ── Security ──
SECURITY_CONFIRM_DANGEROUS_ACTIONS=true
SECURITY_AUTO_APPROVE_SAFE=true
SECURITY_MAX_SHELL_TIMEOUT=30

# ── UI ──
UI_HOST=127.0.0.1
UI_PORT=8400
UI_CORS_ORIGINS=http://localhost:5173,http://localhost:8400
