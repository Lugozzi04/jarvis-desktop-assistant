{
  "name": "jarvis-desktop-assistant",
  "version": "0.3.0",
  "description": "Jarvis Desktop Assistant — LLM-powered personal assistant with native webview window",
  "private": true,
  "scripts": {
    "setup": "cd frontend && npm install",
    "build": "cd frontend && npm run build",
