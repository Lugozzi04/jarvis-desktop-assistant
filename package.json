{
  "name": "jarvis-desktop-assistant",
  "version": "0.3.0",
  "description": "Jarvis Desktop Assistant — LLM-powered personal assistant",
  "private": true,
  "scripts": {
    "setup": "cd frontend && npm install",
    "build": "cd frontend && npm run build",
    "dev": "cd frontend && npm run dev",
    "electron": "cd frontend && npx electron .",
    "backend": ".venv\\Scripts\\python.exe -m uvicorn backend.main:app --host 127.0.0.1 --port 8400",
    "start": "powershell -ExecutionPolicy Bypass -File start.ps1",
    "test": "python -m pytest tests/ -v",
    "smoke": "python scripts/smoke_test.py",
    "check": "python scripts/check_environment.py"
  }
}
